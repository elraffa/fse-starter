{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1920px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false,
			"palette": [
				{
					"slug": "base",
					"color": "#ffffff",
					"name": "Base"
				},
				{
					"slug": "surface",
					"color": "#f5f3ef",
					"name": "Surface"
				},
				{
					"slug": "contrast",
					"color": "#0a0a0a",
					"name": "Contrast"
				},
				{
					"slug": "accent",
					"color": "#1e3464",
					"name": "Accent"
				},
				{
					"slug": "muted",
					"color": "#6b7280",
					"name": "Muted"
				},
				{
					"slug": "border",
					"color": "#e2ded8",
					"name": "Border"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"slug": "xs",
					"size": "0.5rem",
					"name": "XS — 8px"
				},
				{
					"slug": "sm",
					"size": "1rem",
					"name": "S — 16px"
				},
				{
					"slug": "md",
					"size": "2rem",
					"name": "M — 32px"
				},
				{
					"slug": "lg",
					"size": "clamp(3rem, 6vw, 4.5rem)",
					"name": "L — 48–72px"
				},
				{
					"slug": "xl",
					"size": "clamp(4.5rem, 9vw, 7rem)",
					"name": "XL — 72–112px"
				},
				{
					"slug": "2xl",
					"size": "clamp(6rem, 12vw, 10rem)",
					"name": "2XL — 96–160px"
				},
				{
					"slug": "3xl",
					"size": "clamp(8rem, 16vw, 14rem)",
					"name": "3XL — 128–224px"
				}
			],
			"units": [ "%", "px", "em", "rem", "vh", "vw" ]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "sans",
					"name": "Manrope",
					"fontFamily": "Manrope, ui-sans-serif, system-ui, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "300 800",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/manrope-latin-ext.woff2" ],
							"unicodeRange": "U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF"
						},
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "300 800",
							"fontDisplay": "swap",
							"src": [ "file:./assets/fonts/manrope-latin.woff2" ],
							"unicodeRange": "U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD"
						}
					]
				},
				{
					"slug": "mono",
					"name": "Monospace",
					"fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace"
				}
			],
			"fontSizes": [
				{
					"slug": "sm",
					"name": "Small",
					"size": "clamp(0.875rem, 0.8rem + 0.375vw, 1rem)"
				},
				{
					"slug": "base",
					"name": "Base",
					"size": "clamp(1rem, 0.9rem + 0.5vw, 1.125rem)"
				},
				{
					"slug": "lg",
					"name": "Large",
					"size": "clamp(1.125rem, 1rem + 0.625vw, 1.25rem)"
				},
				{
					"slug": "xl",
					"name": "X-Large",
					"size": "clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem)"
				},
				{
					"slug": "2xl",
					"name": "2X-Large",
					"size": "clamp(1.5rem, 1.25rem + 1.25vw, 2rem)"
				},
				{
					"slug": "3xl",
					"name": "3X-Large",
					"size": "clamp(1.875rem, 1.5rem + 1.875vw, 2.625rem)"
				},
				{
					"slug": "4xl",
					"name": "4X-Large",
					"size": "clamp(2.25rem, 1.75rem + 2.5vw, 3.5rem)"
				}
			]
		},
		"custom": {
			"spacing": {
				"gap": "clamp(1rem, 2vw, 1.5rem)"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "var(--wp--custom--spacing--gap)",
			"padding": {
				"top": "0px",
				"bottom": "0px",
				"left": "clamp(1.25rem, 4vw, 3rem)",
				"right": "clamp(1.25rem, 4vw, 3rem)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--contrast)"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--4xl)",
					"lineHeight": "1.08",
					"fontWeight": "700",
					"letterSpacing": "-0.03em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--3xl)",
					"lineHeight": "1.12",
					"fontWeight": "700",
					"letterSpacing": "-0.025em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--2xl)",
					"lineHeight": "1.2",
					"fontWeight": "600",
					"letterSpacing": "-0.015em"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xl)",
					"lineHeight": "1.3",
					"fontWeight": "600",
					"letterSpacing": "-0.01em"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "var(--wp--preset--color--base)"
				},
				"typography": {
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--sm)"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"bottom": "0.75rem",
						"left": "1.5rem",
						"right": "1.5rem"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--sm)",
					"fontWeight": "500"
				}
			},
			"core/query": {
				"spacing": {
					"blockGap": "var(--wp--custom--spacing--gap)"
				}
			},
			"core/post-title": {
				"typography": {
					"fontWeight": "700"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-no-title",
			"title": "Page (No Title)",
			"postTypes": [ "page" ]
		}
	]
}
